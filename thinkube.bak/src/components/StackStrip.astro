---
/**
 * Stack Strip component — visual representation of the Thinkube platform layers
 * Shows grouped service badges organized by layer (AI, Platform, Infrastructure)
 */

const layers = [
  {
    label: 'AI & ML',
    badges: ['AI Notebooks', 'Experiment Tracking', 'GPU Management'],
  },
  {
    label: 'Development',
    badges: ['Hosted VS Code', 'Git Server', 'CI/CD Pipelines', 'GitOps'],
  },
  {
    label: 'Platform',
    badges: ['Single Sign-On', 'Container Registry', 'SQL Database', 'Object Storage (S3)', 'Shared Filesystem'],
  },
  {
    label: 'Optional',
    badges: ['Local LLM Inference', 'Vector Databases', 'Serverless', 'Metrics & Dashboards', 'LLM Observability'],
    isOptional: true,
  },
];
---

<div class="stack-strip">
  {layers.map((layer) => (
    <div class:list={["stack-row", { "stack-optional": layer.isOptional }]}>
      <span class="stack-layer-label">{layer.label}</span>
      <div class="stack-badges">
        {layer.badges.map((badge) => (
          <span class="stack-badge">{badge}</span>
        ))}
        {!layer.isOptional && <span class="stack-badge stack-more">+more</span>}
      </div>
    </div>
  ))}
</div>

<style>
  .stack-strip {
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .stack-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .stack-layer-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sl-color-gray-3);
    width: 100px;
    flex-shrink: 0;
    text-align: right;
  }

  .stack-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .stack-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 500;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    color: var(--sl-color-gray-2);
    white-space: nowrap;
  }

  .stack-more {
    font-style: italic;
    opacity: 0.6;
    border-style: dashed;
  }

  :root[data-theme="light"] .stack-badge {
    color: #4a4a4a;
    background: #f5f5f3;
  }

  :root[data-theme="light"] .stack-layer-label {
    color: #888;
  }

  /* First row (AI) gets amber accent */
  .stack-row:first-child .stack-badge:not(.stack-more) {
    border-color: rgba(196, 163, 90, 0.3);
  }

  /* Optional row gets dashed borders */
  .stack-optional .stack-badge {
    border-style: dashed;
    opacity: 0.7;
  }

  @media (max-width: 639px) {
    .stack-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }

    .stack-layer-label {
      text-align: left;
      width: auto;
    }
  }
</style>
