---
/**
 * Timeline Block component for "A Day With Thinkube" section
 * Shows a time-of-day label with icon on the left, content on the right
 */
import {
  Coffee,
  Sun,
  Moon,
  Clock,
} from '@lucide/astro';

interface Props {
  time: string;
  icon: string;
}

const { time, icon } = Astro.props;

const iconMap: Record<string, any> = {
  coffee: Coffee,
  sun: Sun,
  moon: Moon,
  clock: Clock,
};

const IconComponent = iconMap[icon] || Clock;
---

<div class="timeline-entry">
  <div class="timeline-marker">
    <IconComponent size={20} />
    <span class="time-label">{time}</span>
  </div>
  <div class="timeline-content">
    <slot />
  </div>
</div>

<style>
  .timeline-entry {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .timeline-entry:last-child {
    border-bottom: none;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--sl-color-accent);
    padding-top: 0.25rem;
  }

  .time-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sl-color-accent);
  }

  .timeline-content {
    min-width: 0;
  }

  .timeline-content :global(p) {
    margin: 0 0 0.75rem;
  }

  .timeline-content :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 639px) {
    .timeline-entry {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .timeline-marker {
      flex-direction: row;
      justify-content: flex-start;
      gap: 0.5rem;
    }
  }
</style>
