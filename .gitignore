# build output (Antora)
build/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# local scratch (browser screenshots / playwright)
.playwright-mcp/
*-render.png

# more local scratch
*-final.png
*.tmp.png

# Machine-specific MCP config — regenerated per-machine by the Tandem bundle installer
.mcp.json

# Local / runtime Claude state — never commit (may hold local settings or secrets)
.claude/settings.local.json
.claude/*.local.json
.claude/scheduled_tasks.lock
.claude/.bundle-version.json
