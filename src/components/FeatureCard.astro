---
/**
 * Feature Card component with Lucide icons
 * Used on homepage for feature highlights
 */
import {
  Rocket,
  Settings,
  CircleCheck,
  Sparkles,
  Download,
  Puzzle,
  BookOpen,
  Layers,
  Server,
  Shield,
  GitBranch,
  Cpu,
  Database,
  Globe,
  Terminal,
  Workflow
} from 'lucide-astro';

interface Props {
  title: string;
  icon: string;
}

const { title, icon } = Astro.props;

// Map icon names to Lucide components
const iconMap: Record<string, any> = {
  rocket: Rocket,
  settings: Settings,
  check: CircleCheck,
  sparkles: Sparkles,
  download: Download,
  puzzle: Puzzle,
  book: BookOpen,
  layers: Layers,
  server: Server,
  shield: Shield,
  git: GitBranch,
  cpu: Cpu,
  database: Database,
  globe: Globe,
  terminal: Terminal,
  workflow: Workflow,
};

const IconComponent = iconMap[icon] || Rocket;
---

<div class="feature-card">
  <div class="icon-wrapper">
    <IconComponent size={24} />
  </div>
  <div class="content">
    <h3>{title}</h3>
    <slot />
  </div>
</div>

<style>
  .feature-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
  }

  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent);
  }

  .content h3 {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .content :global(p) {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }

  :root[data-theme="light"] .content h3 {
    color: #1a1a1a;
  }

  :root[data-theme="light"] .content :global(p) {
    color: #4a4a4a;
  }
</style>
